{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aikdna.com/schemas/trace.schema.json",
  "title": "KDNA Consumption Trace",
  "type": "object",
  "required": ["type", "schema_version", "trace_id", "timestamp", "operation", "decision"],
  "properties": {
    "type": { "const": "kdna.consumption-trace" },
    "schema_version": { "const": "0.1.0" },
    "trace_id": {
      "type": "string",
      "pattern": "^[0-9a-f]{32}$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "operation": {
      "type": "string",
      "description": "task verb: review, decide, compose, etc."
    },
    "decision": {
      "type": "object",
      "required": ["primary", "rejected", "budget_profile"],
      "properties": {
        "primary": {
          "type": "object",
          "properties": {
            "domain_id": { "type": "string" },
            "weight": { "type": "number" },
            "reason": { "type": "string" }
          }
        },
        "advisors": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "domain_id": { "type": "string" },
              "weight": { "type": "number" },
              "role": { "type": "string" }
            }
          }
        },
        "rejected": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "domain_id": { "type": "string" },
              "reason": { "type": "string" }
            }
          }
        },
        "budget_profile": { "type": "string" },
        "confidence": { "type": "string" },
        "abstain_reason": { "type": "string" }
      }
    },
    "cost": {
      "type": "object",
      "properties": {
        "tokens_consumed": { "type": "integer", "minimum": 0 },
        "chars_consumed": {
          "type": "integer",
          "minimum": 0,
          "description": "Characters independently observed or explicitly reported as consumed. Delivery alone must not increment this value."
        },
        "chars_consumed_basis": {
          "type": "string",
          "enum": ["not_observed", "agent_host_report", "independent_measurement"],
          "description": "Evidence basis for chars_consumed, for example not_observed or agent_host_report."
        },
        "projection_chars": {
          "type": "integer",
          "minimum": 0,
          "description": "Characters in the prepared serialized projection before delivery."
        },
        "projection_chars_delivered": {
          "type": "integer",
          "minimum": 0,
          "description": "Prepared projection characters delivered to a correlated Agent host. This is not a consumption claim."
        },
        "projection_char_delivery_basis": {
          "type": "string",
          "enum": [
            "runtime_serialized_projection",
            "not_delivered",
            "delivery_unconfirmed",
            "withheld_by_budget",
            "not_reported"
          ],
          "description": "Runtime observation basis for projection_chars_delivered."
        },
        "assets_loaded": { "type": "integer", "minimum": 0 },
        "over_budget": { "type": "boolean" }
      }
    },
    "projection": {
      "type": "object",
      "properties": {
        "shape": {
          "type": "string",
          "enum": ["answer-pattern", "compact", "scenario", "full"]
        }
      }
    },
    "provenance": {
      "type": "object",
      "properties": {
        "route_card_version": { "type": "string" },
        "consumer_index_version": { "type": "string" },
        "policy_input_hash": { "type": "string" }
      }
    }
  }
}
