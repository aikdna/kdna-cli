{
  "format": "kdna-cluster",
  "format_version": "0.9.0",
  "cluster_id": "@aikdna/example_cluster",
  "name": "Example Cluster",
  "version": "0.1.0",
  "description": "[TODO: Describe what judgment system this cluster provides.]",
  "type": "vertical",
  "status": "draft",
  "access": "public",
  "domains": [
    {
      "id": "@aikdna/sub_domain_one",
      "version": "^0.1.0",
      "role": "primary-candidate",
      "required": true,
      "load_condition": "[TODO: Task condition for primary domain activation]"
    },
    {
      "id": "@aikdna/sub_domain_two",
      "version": "^0.1.0",
      "role": "advisor",
      "required": false,
      "load_condition": "[TODO: Task condition for advisor activation]",
      "contribution_hypothesis_template": "[TODO: What distinct dimension does this advisor add beyond the primary?]"
    }
  ],
  "composition": {
    "strategy": "signal_based",
    "max_active_domains": 3,
    "conflict_policy": "surface",
    "priority_order": ["@aikdna/sub_domain_one", "@aikdna/sub_domain_two"],
    "primary_selection": "exactly_one",
    "advisor_selection": "contribution_hypothesis_required"
  },
  "budget": {
    "profile": "interactive",
    "max_tokens": 800,
    "max_assets": 3,
    "enforcement": "hard"
  },
  "degradation_policy": {
    "primary_unavailable": "block",
    "required_advisor_unavailable": "block",
    "optional_advisor_unavailable": "continue_with_warning",
    "budget_exceeded": "block"
  }
}
