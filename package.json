{
  "name": "@aikdna/kdna-cli",
  "version": "0.28.0",
  "description": "KDNA CLI — runtime control plane for inspecting, validating, planning, packing, unpacking, and loading local .kdna assets.",
  "type": "commonjs",
  "bin": {
    "kdna": "src/cli.js",
    "kdna-lint": "validators/kdna-lint.js",
    "kdna-validate": "validators/kdna-validate.js"
  },
  "files": [
    "src/",
    "validators/",
    "templates/",
    "skills/",
    "LICENSE",
    "NOTICE",
    "SECURITY.md",
    "schema/",
    "fixtures/"
  ],
  "scripts": {
    "lint": "eslint src/ validators/ tests/",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "npm run test:v1 && npm run test:smoke",
    "test:integration": "node --test tests/integration.test.js",
    "test:all": "npm run test:v1 && npm run test:smoke && npm run test:legacy",
    "test:core-smoke": "node scripts/pretest-smoke.js",
    "release:preflight": "node scripts/release-preflight.js",
    "test:v1": "node --test tests/v1-global-cli.test.js tests/v1-demo-minimal.test.js",
    "test:smoke": "npm run test:core-smoke",
    "test:legacy": "node --test tests/v07-commands.test.js tests/v012-commands.test.js tests/asset-store.test.js",
    "test:demo": "node --test tests/v1-demo-minimal.test.js",
    "prepublishOnly": "npm test && npm run release:check",
    "release:check": "node scripts/release-check.js"
  },
  "keywords": [
    "kdna",
    "kdna-cli",
    "ai-agent",
    "domain-judgment",
    "cli",
    "judgment-asset",
    "official-toolchain"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aikdna/kdna-cli.git"
  },
  "homepage": "https://aikdna.com",
  "bugs": {
    "url": "https://github.com/aikdna/kdna-cli/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@aikdna/kdna-core": "^0.13.2"
  },
  "optionalDependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "cbor-x": "^1.6.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "eslint": "^9.39.0",
    "prettier": "^3.8.3"
  }
}
