{
  "name": "@aikdna/kdna-cli",
  "version": "0.22.0",
  "description": "KDNA CLI — runtime control plane for verifying, installing, loading, comparing, publishing, and auditing existing .kdna assets.",
  "type": "commonjs",
  "bin": {
    "kdna": "src/cli.js",
    "kdna-lint": "validators/kdna-lint.js",
    "kdna-validate": "validators/kdna-validate.js"
  },
  "files": [
    "src/",
    "validators/",
    "templates/",
    "skills/",
    "LICENSE",
    "NOTICE",
    "SECURITY.md",
    "schema/",
    "fixtures/"
  ],
  "scripts": {
    "lint": "eslint src/ validators/ tests/",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "npm run test:core-smoke; node --test tests/v07-commands.test.js tests/v012-commands.test.js tests/asset-store.test.js; node --test tests/v1-global-cli.test.js",
    "test:integration": "node --test tests/integration.test.js",
    "test:all": "npm run test:core-smoke && node --test tests/*.test.js",
    "test:core-smoke": "node scripts/pretest-smoke.js",
    "release:preflight": "node scripts/release-preflight.js"
  },
  "keywords": [
    "kdna",
    "kdna-cli",
    "ai-agent",
    "domain-judgment",
    "judgment-protocol",
    "cli"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aikdna/kdna-cli.git"
  },
  "homepage": "https://aikdna.com",
  "bugs": {
    "url": "https://github.com/aikdna/kdna-cli/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@aikdna/kdna-core": "^0.9.1"
  },
  "optionalDependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "cbor-x": "^1.6.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "eslint": "^9.39.0",
    "prettier": "^3.8.3"
  }
}
